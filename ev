#!/usr/bin/env bash
# Daily refresh: all leagues, dfs + books scrape → normalize → EV (see --help).
# Example: ./ev --books dk --timing
set -euo pipefail
ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT/backend"
if [[ -f .venv/bin/activate ]]; then
  # shellcheck source=/dev/null
  source .venv/bin/activate
fi
exec python -m core.pipeline_runner "$@"
