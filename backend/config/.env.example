# Dabble Credentials
DABBLE_USERNAME=your_phone_number
DABBLE_PASSWORD=your_password

# Betr auth (pick one path). See docs/betting_odds/betr.md → Authentication.
# Manual JWT from fantasy.betr.app DevTools → Authorization (no "Bearer " prefix).
BETR_BEARER_TOKEN=

# Optional: auto-refresh via Keycloak (password or refresh grant).
# BETR_KEYCLOAK_TOKEN_URL=https://<host>/realms/<realm>/protocol/openid-connect/token
# If omitted, derived from JWT iss when BETR_BEARER_TOKEN is set.
# BETR_KEYCLOAK_CLIENT_ID=betr-web
# BETR_USERNAME=
# BETR_PASSWORD=
# BETR_REFRESH_TOKEN=
