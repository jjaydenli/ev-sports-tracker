# Betr auth — see docs/betting_odds/betr.md → Authentication.
# Probe: cd backend && python -m scrapers.dfs.betr.betr_auth [--try-grant]

# Recommended: refresh grant (hands-free daily ./ev runs).
# Capture refresh_token from DevTools; see betr.md → Authentication.
BETR_REFRESH_TOKEN=
# Betr Keycloak realm endpoint (public; same for all users). Omit only if a JWT iss or
# data/processed/.betr_token_cache.json can supply it — see betr.md.
BETR_KEYCLOAK_TOKEN_URL=https://account.betr.app/realms/betr/protocol/openid-connect/token
# Must match DevTools form body client_id on the token POST that issued your refresh_token.
# fantasy.betr.app typically uses betr-rn (mobile/RN client), not betr-web (code default).
BETR_KEYCLOAK_CLIENT_ID=betr-rn

# Alternative: manual JWT from fantasy.betr.app DevTools → Authorization (no "Bearer " prefix).
# When set (even if expired), iss can supply BETR_KEYCLOAK_TOKEN_URL for refresh above.
# BETR_BEARER_TOKEN=

# Alternative: password grant (same BETR_KEYCLOAK_* vars as refresh).
# BETR_USERNAME=
# BETR_PASSWORD=

# FanDuel sportsbook (optional). Default NJ sbapi host; see docs/betting_odds/fanduel.md
# FD_SPORTSBOOK_API_HOST=https://sbapi.nj.sportsbook.fanduel.com
# FD_API_KEY=FhMFpcPWXMeyZxOx

# Multi-book consensus weights when DK and FD both have exact O/U at the Betr line (default 1.0 each).
# SHARP_BOOK_WEIGHTS_DK=1.0
# SHARP_BOOK_WEIGHTS_FD=1.0

# DraftKings markets scrape: max parallel subcategory HTTP calls (default 6, max 16).
# Lower if you see 403 Access Denied from Akamai; raise for faster scrapes on a clean IP.
# DK_MARKETS_MAX_CONCURRENT=6

# Archived — Dabble integration lives under backend/archive/dabble/
# DABBLE_USERNAME=your_phone_number
# DABBLE_PASSWORD=your_password
