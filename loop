#!/usr/bin/env bash
# Timed ./ev loop with a desktop toast on new +EV matches.
# Usage: ./loop [--loop-seconds N] [--min-ev X] [<any ./ev args>]
#
# Re-runs ./ev back-to-back for a fixed wall-clock window, prints only the
# ranked table (loguru noise suppressed), and fires an OS-native toast the
# first time a prop crosses --min-ev within this run.
set -euo pipefail

usage() {
  cat <<'EOF'
./loop — re-run ./ev back-to-back for a fixed window; toast on new +EV props.

Usage: ./loop [--loop-seconds N] [--min-ev X] [<any ./ev args>]

  --loop-seconds N   wall-clock cap in seconds (default 300). Loop-owned; the
                     in-flight ./ev run always finishes, the cap is checked
                     between runs. NOT forwarded to ./ev.
  --min-ev X         forwarded to ./ev; a fraction (default 0.02 = 2%). It both
                     filters the table and defines the toast threshold.
  --nba|--mlb|--wnba|--leagues …   forwarded; if no league flag is given, --mlb
                     is injected.
  -h, --help         show this help and exit.

Any other argument is forwarded to ./ev unchanged.
EOF
}

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT/backend"
if [[ -f .venv/bin/activate ]]; then
  # shellcheck source=/dev/null
  source .venv/bin/activate
fi

LOOP_SECONDS=300
# Lower bound on seconds between runs. A healthy ./ev run takes far longer than
# this; the floor only matters if a run returns near-instantly (e.g. an offline
# slate) so the loop paces itself instead of busy-spinning.
MIN_INTERVAL=2
EV_ARGS=()
HAS_LEAGUE=0
HAS_MIN_EV=0

die() { printf 'loop: %s\n' "$1" >&2; exit 1; }

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --loop-seconds)
      [[ $# -ge 2 ]] || die "--loop-seconds needs a value"
      [[ $2 =~ ^[0-9]+$ && $2 -gt 0 ]] || die "--loop-seconds must be a positive integer (got '$2')"
      LOOP_SECONDS="$2"
      shift 2
      ;;
    --min-ev)
      [[ $# -ge 2 ]] || die "--min-ev needs a value"
      HAS_MIN_EV=1
      EV_ARGS+=("$1" "$2")
      shift 2
      ;;
    --nba|--mlb|--wnba)
      HAS_LEAGUE=1
      EV_ARGS+=("$1")
      shift
      ;;
    --leagues)
      [[ $# -ge 2 ]] || die "--leagues needs a value"
      HAS_LEAGUE=1
      EV_ARGS+=("$1" "$2")
      shift 2
      ;;
    --leagues=*)
      HAS_LEAGUE=1
      EV_ARGS+=("$1")
      shift
      ;;
    *)
      EV_ARGS+=("$1")
      shift
      ;;
  esac
done

[[ $HAS_LEAGUE -eq 0 ]] && EV_ARGS+=("--mlb")
[[ $HAS_MIN_EV -eq 0 ]] && EV_ARGS=("--min-ev" "0.02" "${EV_ARGS[@]}")

NOTIFIED_FILE=$(mktemp)
TOAST_FILE=$(mktemp)
EV_LOG=$(mktemp)
trap 'rm -f "$NOTIFIED_FILE" "$TOAST_FILE" "$EV_LOG"' EXIT
export NOTIFIED_FILE TOAST_FILE

# --- OS-agnostic notification backend ---------------------------------------
# Detected once. WSL is Linux + a Microsoft kernel, so it must be checked before
# the generic-Linux branch.
POWERSHELL="/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe"
detect_notify_backend() {
  case "$(uname -s)" in
    Darwin)
      command -v osascript >/dev/null 2>&1 && { echo macos; return; }
      ;;
    Linux)
      if grep -qi microsoft /proc/version 2>/dev/null && [[ -x "$POWERSHELL" ]]; then
        echo wsl; return
      fi
      command -v notify-send >/dev/null 2>&1 && { echo linux; return; }
      ;;
  esac
  echo none
}
NOTIFY_BACKEND="$(detect_notify_backend)"

notify_wsl() {  # title, body
  local title="${1//\'/\'\'}" body="${2//\'/\'\'}"
  local ps1file="/mnt/c/Windows/Temp/ev_loop_toast_$$.ps1"
  cat > "$ps1file" <<PS1EOF
[Windows.UI.Notifications.ToastNotificationManager, Windows.UI.Notifications, ContentType = WindowsRuntime] | Out-Null
\$template = [Windows.UI.Notifications.ToastTemplateType]::ToastText02
\$xml = [Windows.UI.Notifications.ToastNotificationManager]::GetTemplateContent(\$template)
\$text = \$xml.GetElementsByTagName('text')
\$text.Item(0).AppendChild(\$xml.CreateTextNode('${title}')) | Out-Null
\$text.Item(1).AppendChild(\$xml.CreateTextNode('${body}')) | Out-Null
\$toast = [Windows.UI.Notifications.ToastNotification]::new(\$xml)
\$appid = '{1AC14E77-02E7-4E5D-B744-2EB1AE5198B7}\WindowsPowerShell\v1.0\powershell.exe'
[Windows.UI.Notifications.ToastNotificationManager]::CreateToastNotifier(\$appid).Show(\$toast)
PS1EOF
  "$POWERSHELL" -NoProfile -NonInteractive -ExecutionPolicy Bypass -File "$(wslpath -w "$ps1file")" \
    || printf 'loop: toast failed (powershell)\n' >&2
  rm -f "$ps1file"
}

notify() {  # title, body — dispatch to the detected backend
  local title="$1" body="$2"
  case "$NOTIFY_BACKEND" in
    wsl)   notify_wsl "$title" "$body" ;;
    macos) osascript -e "display notification \"${body//\"/\\\"}\" with title \"${title//\"/\\\"}\"" \
             || printf 'loop: toast failed (osascript)\n' >&2 ;;
    linux) notify-send "$title" "$body" || printf 'loop: toast failed (notify-send)\n' >&2 ;;
    none)  : ;;  # no backend available on this host; table output still prints
  esac
}
# ----------------------------------------------------------------------------

if [[ "$NOTIFY_BACKEND" == none ]]; then
  printf 'loop: no desktop-notification backend found; running table-only.\n' >&2
fi

START=$(date +%s)
RUN=0

while true; do
  NOW=$(date +%s)
  ELAPSED=$(( NOW - START ))
  [[ $ELAPSED -ge $LOOP_SECONDS ]] && break

  RUN=$(( RUN + 1 ))
  RUN_START=$(date +%s)
  # Suppress loguru (stderr) from the table view but keep it for diagnostics: a
  # non-zero ./ev exit is fatal (bad args won't fix themselves on retry) — abort
  # with the tail of the captured log instead of busy-spinning.
  if ! "$ROOT/ev" "${EV_ARGS[@]}" 2>"$EV_LOG"; then
    printf 'loop: ./ev exited non-zero on run #%d — aborting.\n' "$RUN" >&2
    tail -n 15 "$EV_LOG" >&2 || true
    exit 1
  fi

  NOW=$(date +%s)
  ELAPSED=$(( NOW - START ))
  printf '\n[loop t=%ds run #%d]\n' "$ELAPSED" "$RUN"

  > "$TOAST_FILE"

  python - <<'PYEOF'
import json, os, sys
sys.path.insert(0, '.')
from core.ev_display import format_ev_table_header, format_ev_opportunity_row

notified_path = os.environ['NOTIFIED_FILE']
toast_path    = os.environ['TOAST_FILE']

try:
    with open('data/processed/ev_opportunities.json') as f:
        data = json.load(f)
    props = data.get('props', [])
except (FileNotFoundError, json.JSONDecodeError):
    props = []

try:
    with open(notified_path) as f:
        seen = set(f.read().splitlines())
except FileNotFoundError:
    seen = set()

def prop_key(p):
    return f"{p.get('player','')}|{p.get('market','')}|{p.get('line','')}|{p.get('side','')}|{p.get('league','')}"

BOLD_YELLOW = '\033[1;33m'
RESET = '\033[0m'

if props:
    header = format_ev_table_header()
    print(header)
    print('-' * len(header))
    for p in props:
        row_text = format_ev_opportunity_row(p)
        if prop_key(p) not in seen:
            print(f"{BOLD_YELLOW}{row_text}{RESET}")
        else:
            print(row_text)
else:
    print('(no props)')

new_props = [(prop_key(p), p) for p in props if prop_key(p) not in seen]

if not new_props:
    sys.exit(0)

with open(notified_path, 'a') as f:
    for key, _ in new_props:
        f.write(key + '\n')

n = len(new_props)
_, first = new_props[0]
ev_pct = first.get('ev_pct') or 0.0
body = (
    f"{first.get('player','')} {first.get('market','')} "
    f"{first.get('line','')} {first.get('side','')} +{ev_pct:.1f}%"
)
if n > 1:
    body += f" (+{n-1} more)"

with open(toast_path, 'w') as f:
    f.write(f"EV alert ({n} new, {len(props)} total)\n{body}\n")
PYEOF

  if [[ -s "$TOAST_FILE" ]]; then
    # Portable two-line read (avoids `mapfile`, absent from macOS's bash 3.2).
    TOAST_TITLE=""; TOAST_BODY=""
    { IFS= read -r TOAST_TITLE; IFS= read -r TOAST_BODY; } < "$TOAST_FILE" || true
    notify "${TOAST_TITLE:-EV alert}" "${TOAST_BODY:-}"
  fi

  # Pace the loop so an instant ./ev return can't busy-spin (see MIN_INTERVAL).
  RUN_ELAPSED=$(( $(date +%s) - RUN_START ))
  if [[ $RUN_ELAPSED -lt $MIN_INTERVAL ]]; then
    sleep $(( MIN_INTERVAL - RUN_ELAPSED ))
  fi
done

printf '[loop done: %ds, %d runs]\n' "$ELAPSED" "$RUN"
