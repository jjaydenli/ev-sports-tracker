#!/usr/bin/env bash
# Timed ./ev loop with a desktop toast on new +EV matches.
# Usage: ./loop --help
#
# Re-runs ./ev back-to-back for a fixed wall-clock window, prints only the
# ranked table (loguru noise suppressed), and fires an OS-native toast the
# first time a prop crosses --min-ev within this run.
set -euo pipefail

usage() {
  cat <<'EOF'
usage: ./loop [-h] [--timeout SECS] [--min-ev FRAC] [EV_ARG ...]

Re-run ./ev back-to-back for a fixed window; toast on new +EV props.

Loop options:
  -h, --help            show this help message and exit
  --timeout SECS        wall-clock run cap in seconds (default: 300)

Options forwarded to ./ev:
  --min-ev FRAC         minimum EV fraction (no default; omit for unfiltered board)
  --mlb, --nba, --wnba  league filter shorthand (union)
  --leagues LIST        comma-separated leagues (union with shorthand)

Other ./ev flags pass through unchanged (see ./ev --help).

Examples:
  ./loop --timeout 600
  ./loop --wnba --skip-scrape
  ./loop --min-ev 0.03 --mlb
EOF
}

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT/backend"
if [[ -f .venv/bin/activate ]]; then
  # shellcheck source=/dev/null
  source .venv/bin/activate
fi

LOOP_SECONDS=300
# Lower bound on seconds between runs. A healthy ./ev run takes far longer than
# this; the floor only matters if a run returns near-instantly (e.g. an offline
# slate) so the loop paces itself instead of busy-spinning.
MIN_INTERVAL=2
EV_ARGS=()
MIN_EV_VALUE=""

die() { printf 'loop: %s\n' "$1" >&2; exit 1; }

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --timeout)
      [[ $# -ge 2 ]] || die "--timeout needs a value"
      [[ $2 =~ ^[0-9]+$ && $2 -gt 0 ]] || die "--timeout must be a positive integer (got '$2')"
      LOOP_SECONDS="$2"
      shift 2
      ;;
    --min-ev)
      [[ $# -ge 2 ]] || die "--min-ev needs a value"
      MIN_EV_VALUE="$2"
      EV_ARGS+=("$1" "$2")
      shift 2
      ;;
    --nba|--mlb|--wnba)
      EV_ARGS+=("$1")
      shift
      ;;
    --leagues)
      [[ $# -ge 2 ]] || die "--leagues needs a value"
      EV_ARGS+=("$1" "$2")
      shift 2
      ;;
    --leagues=*)
      EV_ARGS+=("$1")
      shift
      ;;
    *)
      EV_ARGS+=("$1")
      shift
      ;;
  esac
done

NOTIFIED_FILE=$(mktemp)
TOAST_FILE=$(mktemp)
EV_LOG=$(mktemp)
trap 'rm -f "$NOTIFIED_FILE" "$TOAST_FILE" "$TOAST_FILE.keys" "$EV_LOG"' EXIT
export NOTIFIED_FILE TOAST_FILE MIN_EV_VALUE

# --- OS-agnostic notification backend ---------------------------------------
# Detected once. WSL is Linux + a Microsoft kernel, so it must be checked before
# the generic-Linux branch. On macOS prefer terminal-notifier (own NC identity);
# plain osascript is attributed to Script Editor and silently drops on Sequoia
# when that app lacks Notifications permission (exit 0, no banner).
POWERSHELL="/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe"
MACOS_NOTIFY_HINT_SHOWN=0
detect_notify_backend() {
  case "$(uname -s)" in
    Darwin)
      command -v terminal-notifier >/dev/null 2>&1 && { echo terminal-notifier; return; }
      command -v osascript >/dev/null 2>&1 && { echo macos; return; }
      ;;
    Linux)
      if grep -qi microsoft /proc/version 2>/dev/null && [[ -x "$POWERSHELL" ]]; then
        echo wsl; return
      fi
      command -v notify-send >/dev/null 2>&1 && { echo linux; return; }
      ;;
  esac
  echo none
}
NOTIFY_BACKEND="$(detect_notify_backend)"

notify_wsl() {  # title, body
  local title="${1//\'/\'\'}" body="${2//\'/\'\'}"
  local ps1file="/mnt/c/Windows/Temp/ev_loop_toast_$$.ps1"
  cat > "$ps1file" <<PS1EOF
[Windows.UI.Notifications.ToastNotificationManager, Windows.UI.Notifications, ContentType = WindowsRuntime] | Out-Null
\$template = [Windows.UI.Notifications.ToastTemplateType]::ToastText02
\$xml = [Windows.UI.Notifications.ToastNotificationManager]::GetTemplateContent(\$template)
\$text = \$xml.GetElementsByTagName('text')
\$text.Item(0).AppendChild(\$xml.CreateTextNode('${title}')) | Out-Null
\$text.Item(1).AppendChild(\$xml.CreateTextNode('${body}')) | Out-Null
\$toast = [Windows.UI.Notifications.ToastNotification]::new(\$xml)
\$appid = '{1AC14E77-02E7-4E5D-B744-2EB1AE5198B7}\WindowsPowerShell\v1.0\powershell.exe'
[Windows.UI.Notifications.ToastNotificationManager]::CreateToastNotifier(\$appid).Show(\$toast)
PS1EOF
  if ! "$POWERSHELL" -NoProfile -NonInteractive -ExecutionPolicy Bypass -File "$(wslpath -w "$ps1file")"; then
    printf 'loop: toast failed (powershell)\n' >&2
    rm -f "$ps1file"
    return 1
  fi
  rm -f "$ps1file"
  return 0
}

# macOS osascript often exits 0 while NC rejects the connection — treat that as fail.
_macos_osascript_failed() {
  local err_file="$1" rc="$2"
  [[ $rc -ne 0 ]] && return 0
  grep -qiE 'notification center invalid|Connection invalid|ServerConnectionFailure' "$err_file" 2>/dev/null
}

_macos_notify_hint() {
  [[ $MACOS_NOTIFY_HINT_SHOWN -eq 1 ]] && return
  MACOS_NOTIFY_HINT_SHOWN=1
  printf 'loop: macOS toast failed — brew install terminal-notifier, or allow Script Editor in System Settings → Notifications\n' >&2
}

notify_macos_terminal_notifier() {  # title, body
  local title="$1" body="$2" err
  err=$(mktemp)
  if ! terminal-notifier -title "$title" -message "$body" -sound Glass 2>"$err"; then
    printf 'loop: toast failed (terminal-notifier)\n' >&2
    cat "$err" >&2 || true
    rm -f "$err"
    return 1
  fi
  rm -f "$err"
  return 0
}

notify_macos_osascript() {  # title, body
  local title="$1" body="$2" err rc
  err=$(mktemp)
  # argv form avoids shell-quoting bugs; sound makes a silent drop more obvious.
  osascript \
    -e 'on run argv' \
    -e 'display notification (item 2 of argv) with title (item 1 of argv) sound name "Glass"' \
    -e 'end run' \
    -- "$title" "$body" 2>"$err"
  rc=$?
  if _macos_osascript_failed "$err" "$rc"; then
    _macos_notify_hint
    rm -f "$err"
    return 1
  fi
  rm -f "$err"
  return 0
}

notify() {  # title, body — dispatch; 0 on success, 1 on failure
  local title="$1" body="$2"
  case "$NOTIFY_BACKEND" in
    wsl)               notify_wsl "$title" "$body" ;;
    terminal-notifier) notify_macos_terminal_notifier "$title" "$body" ;;
    macos)             notify_macos_osascript "$title" "$body" ;;
    linux)
      if notify-send "$title" "$body"; then
        return 0
      fi
      printf 'loop: toast failed (notify-send)\n' >&2
      return 1
      ;;
    none) return 0 ;;  # table-only; nothing to deliver — still mark keys seen
  esac
}
# ----------------------------------------------------------------------------

if [[ "$NOTIFY_BACKEND" == none ]]; then
  printf 'loop: no desktop-notification backend found; running table-only.\n' >&2
elif [[ "$NOTIFY_BACKEND" == macos ]]; then
  printf 'loop: macOS toast via osascript (Script Editor). Prefer: brew install terminal-notifier\n' >&2
fi

START=$(date +%s)
RUN=0

while true; do
  NOW=$(date +%s)
  ELAPSED=$(( NOW - START ))
  [[ $ELAPSED -ge $LOOP_SECONDS ]] && break

  RUN=$(( RUN + 1 ))
  RUN_START=$(date +%s)
  # Suppress loguru (stderr) from the table view but keep it for diagnostics: a
  # non-zero ./ev exit is fatal (bad args won't fix themselves on retry) — abort
  # with the tail of the captured log instead of busy-spinning.
  if ! "$ROOT/ev" "${EV_ARGS[@]}" 2>"$EV_LOG"; then
    printf 'loop: ./ev exited non-zero on run #%d — aborting.\n' "$RUN" >&2
    tail -n 15 "$EV_LOG" >&2 || true
    exit 1
  fi

  NOW=$(date +%s)
  ELAPSED=$(( NOW - START ))
  printf '\n[loop t=%ds run #%d]\n' "$ELAPSED" "$RUN"

  > "$TOAST_FILE"

  python - <<'PYEOF'
import json, os, sys
sys.path.insert(0, '.')
from core.ev_display import format_ev_opportunities_table

notified_path = os.environ['NOTIFIED_FILE']
toast_path    = os.environ['TOAST_FILE']
min_ev_raw    = os.environ.get('MIN_EV_VALUE', '')
min_ev        = float(min_ev_raw) if min_ev_raw else None

try:
    with open('data/processed/ev_opportunities.json') as f:
        data = json.load(f)
    props = data.get('props', [])
except (FileNotFoundError, json.JSONDecodeError):
    props = []

try:
    with open(notified_path) as f:
        seen = set(f.read().splitlines())
except FileNotFoundError:
    seen = set()

def prop_key(p):
    return f"{p.get('player','')}|{p.get('market','')}|{p.get('line','')}|{p.get('side','')}|{p.get('league','')}"

if props:
    print(format_ev_opportunities_table(
        props,
        highlight=lambda p: prop_key(p) not in seen,
        color_ev=True,
    ))
else:
    print('(no props)')

def toast_eligible(p):
    ev = p.get('ev')
    if ev is None or not (float(ev) > 0):
        return False
    if min_ev is not None and float(ev) < min_ev:
        return False
    return True

new_props = [
    (prop_key(p), p) for p in props
    if prop_key(p) not in seen and toast_eligible(p)
]

if not new_props:
    sys.exit(0)

def format_line(line):
    if line is None:
        return ""
    try:
        f = float(line)
        return str(int(f)) if f == int(f) else str(line)
    except (TypeError, ValueError):
        return str(line)

def format_market(market):
    return str(market or "").replace("_", " ").strip()

def format_toast_body(p):
    # "[name] [o/u] [line] [prop type]" e.g. "Shohei Ohtani over 0.5 home runs"
    player = str(p.get("player") or "").strip()
    side = str(p.get("side") or "").strip().lower()
    line = format_line(p.get("line"))
    market = format_market(p.get("market"))
    return " ".join(part for part in (player, side, line, market) if part)

n = len(new_props)
_, first = new_props[0]
body = format_toast_body(first)
if n > 1:
    body += f" (+{n-1} more)"

# Keys are written only after a successful toast (see bash below) so a silent
# macOS drop can retry on the next iteration.
with open(toast_path, 'w') as f:
    f.write(f"EV alert ({n} new, {len(props)} total)\n{body}\n")
    for key, _ in new_props:
        f.write(key + "\n")
PYEOF

  if [[ -s "$TOAST_FILE" ]]; then
    # Portable read (avoids `mapfile`, absent from macOS's bash 3.2).
    # Line 1 = title, line 2 = body, remaining lines = prop keys to mark notified.
    TOAST_TITLE=""; TOAST_BODY=""
    {
      IFS= read -r TOAST_TITLE
      IFS= read -r TOAST_BODY
      cat > "${TOAST_FILE}.keys"
    } < "$TOAST_FILE" || true
    if notify "${TOAST_TITLE:-EV alert}" "${TOAST_BODY:-}"; then
      cat "${TOAST_FILE}.keys" >> "$NOTIFIED_FILE"
    fi
    rm -f "${TOAST_FILE}.keys"
  fi

  # Pace the loop so an instant ./ev return can't busy-spin (see MIN_INTERVAL).
  RUN_ELAPSED=$(( $(date +%s) - RUN_START ))
  if [[ $RUN_ELAPSED -lt $MIN_INTERVAL ]]; then
    sleep $(( MIN_INTERVAL - RUN_ELAPSED ))
  fi
done

printf '[loop done: %ds, %d runs]\n' "$ELAPSED" "$RUN"
